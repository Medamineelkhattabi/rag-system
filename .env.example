# Copiez ce fichier en `.env` et renseignez vos propres valeurs.

# Embeddings : Gemini (clé gratuite via https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBED_MODEL=gemini-embedding-001

# Génération : API compatible OpenAI (par exemple Ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=

# En-têtes Cloudflare Access (à remplir si l'endpoint est protégé, sinon laisser vide)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Découpage des documents
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Récupération
TOP_K=4

# Index vectoriel persistant
INDEX_DIR=storage

# URL de l'API (utilisée par le frontend Streamlit)
API_URL=http://localhost:8000
